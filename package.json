{
  "name": "trinity-control-refresh",
  "version": "1.0.2-alpha.5.2",
  "description": "Clean refresh of Trinity Baptist Church production control application",
  "author": "Tim Balkwill",
  "main": "electron-main.cjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check": "node --check electron-main.cjs && node --check cue-execution.cjs && node --check preload.cjs && node --check public/app.js",
    "test": "node --test",
    "build:mac": "electron-builder --mac dmg --x64 --arm64 --publish never",
    "verify:mac": "bash build/verify-macos-apps.sh"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "org.trinitybaptist.trinitycontrol.refresh",
    "productName": "Trinity Control Refresh",
    "asar": true,
    "files": [
      "electron-main.cjs",
      "cue-execution.cjs",
      "preload.cjs",
      "public/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Trinity Control Refresh ${version}",
      "artifactName": "Trinity-Control-Refresh-${version}-${arch}.${ext}"
    },
    "afterPack": "build/after-pack.cjs"
  }
}

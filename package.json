{
  "name": "trinity-control",
  "version": "0.8.0-alpha.3",
  "description": "Offline-first church production control application",
  "author": "Tim Balkwill",
  "main": "electron-main.cjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac dmg --x64 --arm64 --publish never"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "org.trinitybaptist.trinitycontrol",
    "productName": "Trinity Control",
    "asar": true,
    "files": ["electron-main.cjs", "preload.cjs", "public/**/*", "package.json"],
    "directories": { "output": "dist" },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    },
    "dmg": {
      "title": "Trinity Control ${version}",
      "artifactName": "Trinity-Control-${version}-${arch}.${ext}"
    }
  }
}
